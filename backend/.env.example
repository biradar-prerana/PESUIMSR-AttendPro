MONGO_URI=mongodb://localhost:27017/cosec-web
JWT_SECRET=change_this_secret
JWT_EXPIRE=30d

# Real email delivery using free Gmail SMTP.
# Use your Gmail address for SMTP_USER and a Google App Password for SMTP_PASS.
# Do not use your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_character_app_password
FROM_EMAIL=yourgmail@gmail.com

# Optional: HR/admin notifications for new employees and late check-ins.
HR_EMAIL=hr@example.com
